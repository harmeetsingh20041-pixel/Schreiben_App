{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; case \"$npm_config_user_agent\" in pnpm/*) ;; *) echo \"Use pnpm instead\" >&2; exit 1 ;; esac'",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "build:ci": "PORT=5173 BASE_PATH=/ VITE_ENABLE_DEMO_MODE=false VITE_ENABLE_PUBLIC_TEACHER_SIGNUP=false VITE_ENABLE_PUBLIC_STUDENT_SIGNUP=true pnpm run build",
    "test": "pnpm run test:unit",
    "test:unit": "pnpm --filter @workspace/german-writing-coach run test:unit && pnpm --dir scripts test",
    "test:unit:coverage": "pnpm --filter @workspace/german-writing-coach run test:unit:coverage",
    "test:e2e": "pnpm --filter @workspace/german-writing-coach run test:e2e",
    "test:e2e:authenticated": "pnpm --filter @workspace/german-writing-coach run test:e2e:authenticated",
    "test:e2e:autosave-regression": "pnpm --filter @workspace/german-writing-coach run test:e2e:autosave-regression",
    "test:e2e:core-workflow": "pnpm --filter @workspace/german-writing-coach run test:e2e:core-workflow",
    "test:e2e:dialog-viewport": "pnpm --filter @workspace/german-writing-coach run test:e2e:dialog-viewport",
    "test:e2e:enrollment-edges": "pnpm --filter @workspace/german-writing-coach run test:e2e:enrollment-edges",
    "test:e2e:offboarding-history": "pnpm --filter @workspace/german-writing-coach run test:e2e:offboarding-history",
    "test:e2e:feedback-modes": "pnpm --filter @workspace/german-writing-coach run test:e2e:feedback-modes",
    "test:e2e:mutations": "pnpm --filter @workspace/german-writing-coach run test:e2e:mutations",
    "test:e2e:practice-live": "pnpm --filter @workspace/german-writing-coach run test:e2e:practice-live",
    "test:e2e:practice-state-matrix": "pnpm --filter @workspace/german-writing-coach run test:e2e:practice-state-matrix",
    "test:e2e:performance": "pnpm --filter @workspace/german-writing-coach run test:e2e:performance",
    "test:e2e:teacher-access": "pnpm --filter @workspace/german-writing-coach run test:e2e:teacher-access",
    "test:e2e:worksheet-live": "pnpm --filter @workspace/german-writing-coach run test:e2e:worksheet-live",
    "test:e2e:worksheet-live-matrix": "pnpm --filter @workspace/german-writing-coach run test:e2e:worksheet-live-matrix",
    "test:e2e:writing-live": "pnpm --filter @workspace/german-writing-coach run test:e2e:writing-live",
    "test:e2e:submission-realtime": "pnpm --filter @workspace/german-writing-coach run test:e2e:submission-realtime",
    "test:e2e:install": "pnpm --filter @workspace/german-writing-coach run test:e2e:install",
    "test:practice-transition-races:linked": "pnpm --dir scripts test:practice-transition-races:linked",
    "test:worksheet-packet:linked": "pnpm --dir scripts test:worksheet-packet:linked",
    "audit:verify": "pnpm --dir scripts audit:verify",
    "audit:verify:launch": "pnpm --dir scripts audit:verify:launch",
    "quality:verify": "pnpm --dir scripts quality:verify",
    "release:verify": "pnpm --dir scripts release:verify",
    "load:writing:production": "pnpm --dir scripts load:writing:production",
    "release:artifact:edge": "pnpm --dir scripts release:artifact:edge",
    "release:artifact:manifest": "pnpm --dir scripts release:artifact:manifest",
    "production:preflight": "pnpm --dir scripts production:preflight",
    "production:preflight:verify": "pnpm --dir scripts production:preflight:verify",
    "production:clean-baseline:collect": "pnpm --dir scripts production:clean-baseline:collect",
    "production:clean-baseline:verify": "pnpm --dir scripts production:clean-baseline:verify",
    "production:migration-parity": "pnpm --dir scripts production:migration-parity",
    "supabase:auth:configure": "pnpm --dir scripts supabase:auth:configure",
    "qstash:recovery": "pnpm --dir scripts qstash:recovery",
    "worksheet-inventory:collect": "pnpm --dir scripts worksheet-inventory:collect",
    "worksheet-inventory:verify": "pnpm --dir scripts worksheet-inventory:verify",
    "worksheet-bank:publish-packet": "pnpm --dir scripts worksheet-bank:publish-packet",
    "worksheet-matrix:verify": "pnpm --dir scripts worksheet-matrix:verify",
    "evaluator-matrix:verify": "pnpm --dir scripts evaluator-matrix:verify",
    "a1-worksheet-drafts:verify": "pnpm --dir scripts a1-worksheet-drafts:verify",
    "a2-worksheet-drafts:verify": "pnpm --dir scripts a2-worksheet-drafts:verify",
    "b1-worksheet-drafts:verify": "pnpm --dir scripts b1-worksheet-drafts:verify",
    "b2-worksheet-drafts:verify": "pnpm --dir scripts b2-worksheet-drafts:verify",
    "worksheet-choice-order:check": "pnpm --dir scripts worksheet-choice-order:check",
    "worksheet-choice-order:write": "pnpm --dir scripts worksheet-choice-order:write",
    "ai-cost:project": "pnpm --dir scripts ai-cost:project",
    "test:edge": "deno test --no-check --allow-env --lock=deno.lock --frozen --node-modules-dir=manual supabase/functions/_shared/ai-spend-accounting.test.ts supabase/functions/_shared/bounded-json-request.test.ts supabase/functions/_shared/chat-completion-provider.test.ts supabase/functions/_shared/prompt-data.test.ts supabase/functions/_shared/provider-outage-recovery.test.ts supabase/functions/_shared/user-auth.test.ts supabase/functions/_shared/worker-api.test.ts supabase/functions/_shared/writing-adjudication.test.ts supabase/functions/_shared/writing-feedback.test.ts supabase/functions/_shared/worksheet-generation.test.ts supabase/functions/prepare-writing-feedback/handler.test.ts supabase/functions/kick-writing-jobs/handler.test.ts supabase/functions/process-writing-jobs/processor.test.ts supabase/functions/generate-practice-worksheet/request.test.ts supabase/functions/process-worksheet-generation-jobs/checkpoint.test.ts supabase/functions/process-worksheet-generation-jobs/provider-config.test.ts supabase/functions/process-worksheet-generation-jobs/prepare.test.ts supabase/functions/process-worksheet-generation-jobs/processor.test.ts supabase/functions/evaluate-practice-attempt/request.test.ts supabase/functions/process-worksheet-answer-jobs/checkpoint.test.ts supabase/functions/process-worksheet-answer-jobs/evaluate.test.ts supabase/functions/process-worksheet-answer-jobs/processor.test.ts supabase/functions/recover-async-jobs/handler.test.ts supabase/functions/provider-transport-diagnostic/worksheet-stage-diagnostic.test.ts supabase/functions/provider-transport-diagnostic/writing-full-diagnostic.test.ts",
    "check:edge": "deno check --lock=deno.lock --frozen --node-modules-dir=manual supabase/functions/*/index.ts supabase/functions/**/*.test.ts",
    "test:db": "supabase test db",
    "verify": "pnpm run typecheck && pnpm run test:unit && pnpm run build:ci",
    "verify:local": "pnpm run audit:verify && pnpm run typecheck && pnpm run test:unit && pnpm run check:edge && pnpm run test:edge && pnpm run build:ci && pnpm audit --prod --audit-level=high && pnpm run test:e2e && pnpm run test:e2e:practice-state-matrix && pnpm run test:db && git diff --check",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "packageManager": "pnpm@11.7.0",
  "private": true,
  "devDependencies": {
    "@supabase/supabase-js": "2.110.0",
    "jsonrepair": "3.15.0",
    "prettier": "^3.8.4",
    "typescript": "~5.9.3"
  },
  "workspaces": [
    "artifacts/*",
    "lib/*",
    "lib/integrations/*",
    "scripts"
  ],
  "catalog": {
    "@replit/vite-plugin-cartographer": "^0.5.21",
    "@replit/vite-plugin-dev-banner": "^0.1.1",
    "@replit/vite-plugin-runtime-error-modal": "^0.0.6",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-query": "^5.90.21",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.23.24",
    "lucide-react": "^0.545.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.23.0",
    "vite": "^7.3.6",
    "wouter": "^3.3.5",
    "zod": "^3.25.76"
  }
}

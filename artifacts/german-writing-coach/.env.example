# Required by the current Replit-style Vite config for local dev/build.
PORT=5173
BASE_PATH=/

# Frontend-safe Supabase variables.
# The app intentionally keeps working without these in Phase 2.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Do not put SUPABASE_SERVICE_ROLE_KEY or DEEPSEEK_API_KEY in frontend env files.

# Required by the current Replit-style Vite config for local dev/build.
PORT=5173
BASE_PATH=/

# Frontend-safe Supabase variables.
# Required for real sign-in and all protected V1 application flows.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Launch hardening toggles. The retired demo flag is not consumed by the app;
# keeping it false preserves the production preflight fail-closed check.
VITE_ENABLE_DEMO_MODE=false
VITE_ENABLE_PUBLIC_TEACHER_SIGNUP=false
VITE_ENABLE_PUBLIC_STUDENT_SIGNUP=true

# Frontend monitoring. Use SENTRY_AUTH_TOKEN/SENTRY_ORG/SENTRY_PROJECT only in CI.
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=local
VITE_APP_RELEASE=
VITE_SENTRY_ENABLE_REPLAY=false

# Do not put SUPABASE_SERVICE_ROLE_KEY, DEEPSEEK_API_KEY, or GEMINI_API_KEY in
# frontend env files.

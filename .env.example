# Local Vite development
PORT=5173
BASE_PATH=/

# Frontend-safe Supabase variables.
# These are public browser variables and must use the VITE_ prefix.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Future server-only variables.
# Never expose these through Vite or import them into frontend code.
SUPABASE_SERVICE_ROLE_KEY=
DEEPSEEK_API_KEY=

# Local Vite development
PORT=5173
BASE_PATH=/

# Frontend-safe Supabase variables.
# These are public browser variables and must use the VITE_ prefix.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Launch hardening toggles.
# Retired pre-V1 flag: the frontend ignores it and production rejects true.
VITE_ENABLE_DEMO_MODE=false
VITE_ENABLE_PUBLIC_TEACHER_SIGNUP=false
VITE_ENABLE_PUBLIC_STUDENT_SIGNUP=true

# Frontend monitoring. The DSN is browser-safe, but auth tokens are not.
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=local
VITE_APP_RELEASE=
VITE_SENTRY_ENABLE_REPLAY=false

# Future server-only variables.
# Never expose these through Vite or import them into frontend code.
SUPABASE_SERVICE_ROLE_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
GEMINI_ALLOW_PRIMARY_AUTH_FAILOVER=false

# CI/deployment only. Never add these as VITE_ variables.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

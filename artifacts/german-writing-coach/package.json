{
  "name": "@workspace/german-writing-coach",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.config.ts --host 0.0.0.0",
    "build": "vite build --config vite.config.ts",
    "serve": "vite preview --config vite.config.ts --host 0.0.0.0",
    "test": "pnpm run test:unit",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:unit:coverage": "vitest run --coverage --config vitest.config.ts",
    "test:e2e": "playwright test --config playwright.config.ts",
    "test:e2e:authenticated": "tsx scripts/run-authenticated-playwright.ts authenticated.workflow.spec.ts",
    "test:e2e:autosave-regression": "tsx scripts/run-authenticated-playwright.ts authenticated.autosave-regression.spec.ts",
    "test:e2e:core-workflow": "tsx scripts/run-authenticated-playwright.ts authenticated.core-workflow.spec.ts",
    "test:e2e:dialog-viewport": "tsx scripts/run-authenticated-playwright.ts authenticated.dialog-viewport.spec.ts",
    "test:e2e:enrollment-edges": "tsx scripts/run-authenticated-playwright.ts authenticated.enrollment-edge.spec.ts",
    "test:e2e:offboarding-history": "tsx scripts/run-authenticated-playwright.ts authenticated.offboarding-history.spec.ts",
    "test:e2e:feedback-modes": "tsx scripts/run-authenticated-playwright.ts authenticated.feedback-modes.spec.ts",
    "test:e2e:mutations": "tsx scripts/run-authenticated-playwright.ts authenticated.teacher-mutations.spec.ts",
    "test:e2e:practice-live": "tsx scripts/run-authenticated-playwright.ts authenticated.practice-live.spec.ts",
    "test:e2e:practice-state-matrix": "tsc -p tsconfig.practice-state-matrix.json --noEmit && playwright test --config playwright.practice-state-matrix.config.ts",
    "test:e2e:performance": "tsx scripts/run-authenticated-playwright.ts authenticated.performance.spec.ts",
    "test:e2e:teacher-access": "tsx scripts/run-authenticated-playwright.ts authenticated.teacher-access.spec.ts",
    "test:e2e:worksheet-live": "tsx scripts/run-authenticated-playwright.ts authenticated.worksheet-live.spec.ts",
    "test:e2e:worksheet-live-matrix": "tsx scripts/run-worksheet-live-matrix.ts",
    "test:e2e:writing-live": "tsx scripts/run-authenticated-playwright.ts authenticated.writing-live.spec.ts",
    "test:e2e:submission-realtime": "tsx scripts/run-authenticated-playwright.ts authenticated.submission-realtime-live.spec.ts",
    "test:e2e:install": "playwright install --with-deps chromium",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit && tsc -p tsconfig.e2e.json --noEmit"
  },
